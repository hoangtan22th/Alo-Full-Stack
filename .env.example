# ==============================================================================
# ALO CHAT SYSTEM ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to '.env' and update the values before running docker-compose.

# Docker Hub Username (For image pulling & tagging in CI/CD)
DOCKER_USERNAME=hoangtan22th
# Docker Hub Personal Access Token or password (To bypass rate limits in Watchtower)
DOCKER_PASSWORD=your-docker-hub-token

# ------------------------------------------------------------------------------
# 1. DATABASE & BROKER INFRASTRUCTURE (RUNNING IN DOCKER)
# ------------------------------------------------------------------------------

# MariaDB Configurations
DB_HOST=mariadb
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root

# MongoDB Configurations
# For message-service, group-service, voting-service, report-service
MONGODB_URI=mongodb://mongodb:27017/alo_chat_db
MONGO_URI=mongodb://mongodb:27017/alo_voting_db

# Redis Configurations (For Caching & BullMQ & Socket Sharing)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# RabbitMQ Configurations
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Service Discovery (Eureka)
EUREKA_DEFAULT_ZONE=http://discovery-service:8761/eureka/

# ------------------------------------------------------------------------------
# 2. SECURITY & JWT CONFIGURATION
# ------------------------------------------------------------------------------
JWT_SECRET=MsHrNEtyzJ1VU7uKnh6BSgwnRu9IlzR78hlhM3eq8KK

# ------------------------------------------------------------------------------
# 3. SMTP EMAIL CONFIGURATION (For OTP & Notifications)
# ------------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# Google App Password (not your Gmail login password)
MAIL_PASSWORD=your-google-app-password

# ------------------------------------------------------------------------------
# 4. AWS S3 CONFIGURATION (For Media/File Uploads)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY=your-aws-access-key-id
AWS_SECRET_KEY=your-aws-secret-access-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=btl-alo-chat

# ------------------------------------------------------------------------------
# 5. THIRD-PARTY INTEGRATIONS
# ------------------------------------------------------------------------------
# Google OAuth Client ID for Google Web/Mobile Login
GOOGLE_CLIENT_ID=201142582497-rpb2m19t9hf928rg3dtsftd53phfmroe.apps.googleusercontent.com

# ------------------------------------------------------------------------------
# 6. EXTERNAL AI SERVICE CONFIGURATIONS (For chatbot-service)
# ------------------------------------------------------------------------------
# Use "dummy" if using local Ollama. Or put your OpenAI/Gemini Key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
