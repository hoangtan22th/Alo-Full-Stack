# ==============================================================================
# ALO CHAT SYSTEM ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to '.env' and update the values before running docker-compose.

# Docker Hub Username (For image pulling & tagging in CI/CD)
DOCKER_USERNAME=xx
# Docker Hub Personal Access Token or password (To bypass rate limits in Watchtower)
DOCKER_PASSWORD=xx

# ------------------------------------------------------------------------------
# 1. DATABASE & BROKER INFRASTRUCTURE (RUNNING IN DOCKER)
# ------------------------------------------------------------------------------

# MariaDB Configurations
DB_HOST=mariadb
DB_PORT=3306
DB_USERNAME=root
# DB_PASSWORD=xx!@xx
DB_PASSWORD=root

# MongoDB Configurations
# For message-service, group-service, voting-service, report-service
MONGODB_URI=mongodb://mongodb:27017/alo_chat_db
MONGO_URI=mongodb://mongodb:27017/alo_voting_db

# Redis Configurations (For Caching & BullMQ & Socket Sharing)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# RabbitMQ Configurations
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Service Discovery (Eureka)
EUREKA_DEFAULT_ZONE=http://discovery-service:8761/eureka/

# ------------------------------------------------------------------------------
# 2. SECURITY & JWT CONFIGURATION
# ------------------------------------------------------------------------------
JWT_SECRET=xx

# ------------------------------------------------------------------------------
# 3. SMTP EMAIL CONFIGURATION (For OTP & Notifications)
# ------------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=xx
# Google App Password (not your Gmail login password)
MAIL_PASSWORD=xx

# ------------------------------------------------------------------------------
# 4. AWS S3 CONFIGURATION (For Media/File Uploads)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY=xx
AWS_SECRET_KEY=xx
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=btl-alo-chat

# Duplicate AWS credentials for services using Node.js SDK naming convention
AWS_ACCESS_KEY_ID=xx
AWS_SECRET_ACCESS_KEY=xx
AWS_BUCKET_NAME=btl-alo-chat

# ------------------------------------------------------------------------------
# 5. THIRD-PARTY INTEGRATIONS
# ------------------------------------------------------------------------------
# Google OAuth Client ID for Google Web/Mobile Login
GOOGLE_CLIENT_ID=xx

# Zego Cloud Configuration (For Video/Voice Calls)
NEXT_PUBLIC_ZEGO_APP_ID=xx
NEXT_PUBLIC_ZEGO_SERVER_SECRET=xx

# Stipop Configuration (For Stickers)
NEXT_PUBLIC_STIPOP_API_KEY=xx

# Livekit Configuration (For Group Calls/Meetings)
LIVEKIT_URL=wss://alo-chat-1qslw46c.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://alo-chat-1qslw46c.livekit.cloud
LIVEKIT_API_KEY=xx
LIVEKIT_API_SECRET=xx

# Expo Mobile Configurations
EXPO_PUBLIC_IP_ADDRESS=54.255.57.50
EXPO_PUBLIC_GOOGLE_CLIENT_ID=201142582497-rpb2m19t9hf928rg3dtsftd53phfmroe.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=201142582497-g4kps9uontafgrufhvl9cmem5hprgf5k.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=201142582497-n9phem5a0ts2e6c83ha7pgiqjganq8ml.apps.googleusercontent.com

# ------------------------------------------------------------------------------
# 6. EXTERNAL AI & API SERVICE CONFIGURATIONS
# ------------------------------------------------------------------------------
# Use "dummy" if using local Ollama. Or put your OpenAI/Gemini Key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Ollama Endpoint Configuration (Use Tailscale IP to connect from AWS Docker to local Laptop Host)
OLLAMA_BASE_URL=http://100.120.13.36:11434

# Chatbot Weather Service Key
WEATHER_API_KEY=xx
